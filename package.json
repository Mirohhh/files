{
  "name": "my-blog",
  "version": "1.0.0",
  "description": "A minimal personal blog",
  "scripts": {
    "build": "node build.js",
    "watch": "node -e \"const{execSync}=require('child_process');const fs=require('fs');fs.watch('./posts',()=>{execSync('node build.js',{stdio:'inherit'})});execSync('node build.js',{stdio:'inherit'});console.log('Watching posts/ for changes...')\""
  },
  "engines": {
    "node": ">=14"
  }
}
